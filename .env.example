# --- Postgres ---
POSTGRES_USER=focus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=focus365
DATABASE_URL=postgres://focus:changeme@db:5432/focus365?sslmode=disable

# --- API ---
API_PORT=8080
JWT_SECRET=change-this-to-a-long-random-string
CORS_ORIGIN=http://localhost:5173

# --- IA (Groq) ---
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Modelo de visión para extraer movimientos de fotos de comprobantes.
# Operator-configurable: si Groq deja de soportar el default, las imágenes darán
# 503 pero CSV/PDF-texto siguen funcionando (usan GROQ_MODEL).
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- Import app de gastos (opcional) ---
GASTOS_API_BASE=https://money.quhou123.com/Api

# --- Producción (Coolify) ---
# COOKIE_SECURE=true   # cookie de refresh con flag Secure (requiere HTTPS)
